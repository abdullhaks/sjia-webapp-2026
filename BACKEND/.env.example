# ===========================================
# SJIA Backend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (MongoDB Atlas Connection String)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/sjiaDB

# JWT Configuration
# Generate strong secrets: openssl rand -base64 32
ACCESS_TOKEN_SECRET=change_this_to_a_strong_random_secret
REFRESH_TOKEN_SECRET=change_this_to_a_different_strong_secret
MAX_AGE=604800000

# Frontend URLs (for CORS)
CLIENT_URL=https://your-frontend-domain.vercel.app
VERCEL_URL=
DOMAIN_URL=
DEV_URL=http://localhost:5173
TEST_URL=http://localhost:4173

# Backend URL
SERVER_URL=http://localhost:3000
DEV_BACKEND_URL=http://localhost:3000
HOSTED_BACKEND_URL=

# Nodemailer (Gmail App Password)
# Generate app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_gmail_app_password

# AWS S3 Configuration (Optional — only needed if using S3 uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# Web Push (VAPID Keys)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
