# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (MongoDB Atlas Connection String)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/sjia

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=complex_secret_key_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (For CORS)
# Add your Vercel URL here after deployment
CLIENT_URL=https://your-frontend-app.vercel.app

# AWS S3 Configuration (Optional - for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
